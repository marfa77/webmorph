# Copy to .env and fill in ( .env is gitignored )
# Get a key: https://aistudio.google.com/apikey

GOOGLE_API_KEY=
# PageSpeed Insights API (Google Cloud): https://developers.google.com/speed/docs/insights/v5/get-started
# Можно отдельный ключ или тот же, если включён API в проекте:
PAGESPEED_API_KEY=
# Optional: GEMINI_API_KEY=   # same key, alternative name
# Optional: GEMINI_MODEL=gemini-2.5-pro
