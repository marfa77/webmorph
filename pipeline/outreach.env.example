# Скопируй в pipeline/.env и заполни (файл .env в git не коммитится)

# Дата первого дня кампании (от неё считаются 14 дней по 20 писем/день и рампинг)
OUTREACH_START_DATE=2025-03-24

# Часовой пояс для подсчёта «сегодня» (лимит в сутки)
# OUTREACH_TZ=Europe/Lisbon

# SMTP — у тебя в Mail это Microsoft Exchange (Microsoft 365). Типичный исходящий сервер:
#   smtp.office365.com : 587 , STARTTLS (как ниже).
# SMTP_USER и SMTP_FROM = тот ящик, под которым логинишься (тот же адрес в обоих полях).
# Если включена MFA: пароль приложения или согласуй с админом «SMTP AUTH» для ящика (иначе только Microsoft Graph API, не этот скрипт).
# Ошибка 535 «SmtpClientAuthentication is disabled for the Tenant» — админ M365 должен включить SMTP AUTH (per-mailbox или org): https://aka.ms/smtp_auth_disabled
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_STARTTLS=1
SMTP_SSL=0
SMTP_USER=customer@pixid.studio
SMTP_PASSWORD=
SMTP_FROM=customer@pixid.studio
SMTP_FROM_NAME=Pavel

# --- Microsoft Graph (обход блокировки SMTP / Security defaults) ---
# Entra ID → App registrations → New → API permissions → Microsoft Graph → Application → Mail.Send → Grant admin consent
# Certificates & secrets → New client secret → значения в .env ниже
# OUTREACH_SEND_BACKEND=graph
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_FROM_USER=customer@pixid.studio

# --- PageSpeed Insights (psi_enrich.py) ---
# PAGESPEED_API_KEY=   # или GOOGLE_API_KEY, если в GCP включён PageSpeed Insights API

# Только лиды с mobile PSI < 55 (после enrich): для send без флага можно включить так:
# OUTREACH_PSI_SLOW_ONLY=1
