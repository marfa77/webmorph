# Скопируй в pipeline/.env и заполни (файл .env в git не коммитится)

# Дата первого дня кампании (от неё считаются 14 дней по 20 писем/день и рампинг)
OUTREACH_START_DATE=2025-03-24

# Часовой пояс для подсчёта «сегодня» (лимит в сутки)
# OUTREACH_TZ=Europe/Lisbon

# SMTP — хост/порт из настроек твоего почтового провайдера для домена (не Gmail-логин).
# Часто: 587 + STARTTLS, или 465 + SSL — смотри документацию хостинга / Zoho / M365 / и т.д.
SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_STARTTLS=1
SMTP_SSL=0
SMTP_USER=support@pixid.studio
SMTP_PASSWORD=
SMTP_FROM=support@pixid.studio
SMTP_FROM_NAME=Pavel
