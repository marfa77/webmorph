# API keys (use: openssl rand -hex 32)
API_KEY_SALT=

# MySQL — connection string (mysql2). Example: mysql://user:pass@127.0.0.1:3306/ogkit
# Local Docker (see docker-compose.yml): mysql://ogkit:ogkit_dev@127.0.0.1:3306/ogkit
DATABASE_URL=

# Auth.js (magic link via Resend). Generate secret: openssl rand -base64 32
AUTH_SECRET=
# Absolute app URL (include NEXT_PUBLIC_BASE_PATH if you use it), e.g. http://localhost:3000 or https://www.webmorp.art
AUTH_URL=
# Resend API key (or set RESEND_API_KEY — both are read)
AUTH_RESEND_KEY=
# Verified sender in Resend, e.g. "OGKit <noreply@yourdomain.com>"
AUTH_EMAIL_FROM=

# Product is shippable without the blocks below. Lemon = optional self-serve checkout; leave empty to use the waitlist on /pricing.

# LemonSqueezy (billing; Merchant of Record — handles EU VAT + US sales tax)
LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_WEBHOOK_SECRET=
LEMON_VARIANT_PRO_MONTHLY=
LEMON_VARIANT_SCALE_MONTHLY=

# Gumroad (Pro license redemption — defaults are in `src/config/gumroad.ts`; no env required to ship)
# Optional: override API product_id from Gumroad → Share → API (must look like `…==` or it is ignored and the code default is used; same rule as UAEProperty).
# GUMROAD_PRODUCT_ID=
# Optional: dedicated pepper for hashing license keys at rest (defaults to AUTH_SECRET).
GUMROAD_LICENSE_HASH_PEPPER=
# Optional: public checkout URL override (default `GUMROAD_CHECKOUT_URL` in `src/config/gumroad.ts`).
# NEXT_PUBLIC_GUMROAD_CHECKOUT_URL=

# Cryptomus (crypto checkout — one invoice per payment; webhook unlocks Pro/Scale for 30 days)
# https://app.cryptomus.com/ — Merchant ID + API key; webhook = https://<your-host>/api/billing/cryptomus/webhook (or with NEXT_PUBLIC_BASE_PATH)
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=
# Optional: override Cryptomus homepage meta (default verification code is set in src/app/layout.tsx)
NEXT_PUBLIC_CRYPTOMUS_SITE_VERIFICATION=

# Telegram (operations monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public URLs
# OGKit is served at the site root.
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_HOST=www.webmorp.art

# Transactional email (optional if AUTH_RESEND_KEY is set)
RESEND_API_KEY=

# Observability
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Cron / webhook security
CRON_SECRET=

# Google Search Console
# 1) Verify site: set meta tag content from GSC → HTML tag method
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# 2) API access: create GCP service account, enable "Google Search Console API",
#    paste full JSON key (single line) below, add service account email as Owner in GSC property.
#    Falls back to GOOGLE_APPLICATION_CREDENTIALS if unset (legacy Vercel env).
GSC_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=
# URL-prefix property (trailing slash), default https://www.webmorp.art/
# GSC_SITE_URL=https://www.webmorp.art/
# Override sitemap URL if needed (default {site}/sitemap.xml)
# GSC_SITEMAP_URL=https://www.webmorp.art/sitemap.xml
# Cron/manual: POST /api/gsc/sitemap, GET /api/gsc/analytics?days=28 (Bearer CRON_SECRET)
# Weekly cron: GET /api/cron/gsc (Mon 04:00 UTC) — sitemap + analytics + Telegram digest

# IndexNow (optional — Bing/Yandex fast indexing). Generate a random key; host must return it at keyLocation.
# Register key in Bing Webmaster IndexNow, then POST /api/indexnow/publish with Bearer CRON_SECRET and JSON { "urls": ["https://..."] }
INDEXNOW_API_KEY=

# Google Analytics 4 (optional — marketing layout only; lazyOnload for INP)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# IndexNow (for SEO submissions)
INDEXNOW_KEY=
